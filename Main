public class Main{
    public static void main(String[] args){
       
    
        //Scanner

        Airline airline = new Airline();        
         Scanner input = new Scanner(System.in);

         Flight flightNumber1 = new Flight("Ps125", "Paris", "TelAviv", 170, 0);
        Flight flightNumber2 = new Flight("TA340", "Tel Aviv", "paris", 240, 0);
        airline.addFlight(flightNumber1);
        airline.addFlight(flightNumber2);

        // יצירת נוסעים והוספתם ישירות לטיסות
        Passenger passengerNumber1 = new Passenger("p1", 24, "123456", 17.8);
        Passenger passengerNumber2 = new Passenger("p1", 35, "7891011", 23.0); 
        Passenger passengerNumber3 = new Passenger("p2", 21, "12131415", 22.9);

        flightNumber1.addPassanger(passengerNumber1);
        flightNumber1.addPassanger(passengerNumber2);
        flightNumber2.addPassanger(passengerNumber3);

         System.err.println("הוספת טיסה חדשה .1הוספת נוסע לטיסה .2 הצגת כל הטיסות .3 חיפוש נוסע לפי דרכון .4 העברת נוסע בין טיסות .5 הטיסה העמוסה ביותר .6 יציאה .0 _ :בחירה ");
          int yourChoice = input.nextInt();      
          
          while(yourChoice != 0 ){
            if(yourChoice == 1) {
                System.out.print("flight number ");
                String number = input.nextLine();
                System.out.print("now place ");
                String from = input.nextLine();
                System.out.print("ending place");
                String to = input.nextLine();
                System.out.print("max of people ");
                int max = input.nextInt();
                input.nextLine(); 
             Flight flight = new Flight(number, from, to, max, 0);
            airline.addFlight(flight);
            }
            else if(yourChoice == 2) {
           System.out.print("number of flight");
                String flightNum = input.nextLine();
                
                Flight f = airline.getFlightByNumber(flightNum);
                if (f != null) {
                    System.out.print("passanger name");
                    String name = input.nextLine();
                    System.out.print("age ");
                    int age = input.nextInt();
                    input.nextLine();  
                    System.out.print("pasport number ");
                    String passport = input.nextLine();
                    System.out.print("wight");
                    double luggage = input.nextDouble();
                    input.nextLine(); 

                    Passenger passenger = new Passenger(name, age, passport, luggage);
                    passenger.cheak(); 

                    if (f.addPassanger(passenger)) {
                        System.out.println("added passanger");
                    }
                }
            }
            else if(yourChoice == 3) {
                String destination = input.nextLine();
                airline.printFlightsTo(destination);
            }
            
            else if(yourChoice == 4 ){
            System.out.print("passport number");
            String passport = input.nextLine(); 
    
            System.out.print("flight number");
