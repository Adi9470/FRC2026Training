            Flight flight = airline.getFlightByNumber(flightNum);
    
             if(flight != null) {
        
             Passenger pasenger = flight.findPassenger(passport);
        
                 if(pasenger != null) {
                 System.out.println(pasenger.toString());
                 } else {
                 System.out.println("not on");
                 }
             } 
         
            }
        else if(yourChoice == 5) {
                System.out.print("passport number ");
                String passport = input.nextLine();
                System.out.print("form flight ");
                String fromFlight = input.nextLine();
                System.out.print("destaniton flight");
